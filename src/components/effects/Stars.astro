---
interface Props {
  count?: number
  maxOpacity?: number
}

const { count = 80, maxOpacity = 0.7 } = Astro.props
---

<div class="stars-canvas" id="stars-canvas"></div>

<script is:inline define:vars={{ count, maxOpacity }}>
function initStars() {
  const canvas = document.getElementById('stars-canvas')
  if (!canvas) return

  canvas.innerHTML = ''
  const chars = ['\u00b7', ':', '*', '.', '+', '\u2022', '\u2027']
  const stars = []

  // Center reference
  let cx = window.innerWidth / 2
  let cy = window.innerHeight / 2

  for (let i = 0; i < count; i++) {
    const span = document.createElement('span')
    span.className = 'star'

    const x = Math.random() * window.innerWidth
    const y = Math.random() * window.innerHeight
    const size = 7 + Math.random() * 11
    // Depth: 0 = far (barely moves), 1 = close (moves most)
    const depth = 0.15 + Math.random() * 0.85
    // Twinkle timing
    const dur = 3 + Math.random() * 5
    const delay = Math.random() * 7

    span.textContent = chars[Math.floor(Math.random() * chars.length)]
    span.style.left = x + 'px'
    span.style.top = y + 'px'
    span.style.fontSize = size + 'px'
    span.style.setProperty('--dur', dur + 's')
    span.style.setProperty('--delay', delay + 's')
    span.style.setProperty('--max-opacity', (maxOpacity * (0.4 + depth * 0.6)).toFixed(3))
    span.style.setProperty('--min-opacity', (maxOpacity * 0.08).toFixed(3))
    // Deeper stars transition slower — feels like inertia (Emil: spring-like lag)
    span.style.transition = 'translate ' + (0.6 + (1 - depth) * 1.4).toFixed(2) + 's cubic-bezier(0.23, 1, 0.32, 1)'

    canvas.appendChild(span)
    stars.push({ el: span, depth: depth })
  }

  // Mouse parallax
  let targetX = 0
  let targetY = 0
  let ticking = false

  function update() {
    for (let i = 0; i < stars.length; i++) {
      const s = stars[i]
      const moveX = targetX * s.depth * 18
      const moveY = targetY * s.depth * 12
      s.el.style.translate = moveX.toFixed(1) + 'px ' + moveY.toFixed(1) + 'px'
    }
    ticking = false
  }

  document.addEventListener('mousemove', function(e) {
    // Normalize to -1..1 from center
    targetX = (e.clientX - cx) / cx
    targetY = (e.clientY - cy) / cy
    if (!ticking) {
      requestAnimationFrame(update)
      ticking = true
    }
  })

  // Recalc center on resize
  window.addEventListener('resize', function() {
    cx = window.innerWidth / 2
    cy = window.innerHeight / 2
  })
}
initStars()
document.addEventListener('astro:page-load', initStars)
</script>

<style is:global>
  .stars-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .star {
    position: absolute;
    color: var(--text);
    font-family: var(--mono);
    translate: 0 0;
    animation: twinkle var(--dur) ease-in-out infinite var(--delay);
    will-change: translate;
  }

  @keyframes twinkle {
    0%, 100% { opacity: var(--min-opacity); }
    50% { opacity: var(--max-opacity); }
  }

  @media (prefers-reduced-motion: reduce) {
    .star {
      animation: none;
      opacity: var(--min-opacity);
      transition: none !important;
    }
  }
</style>
