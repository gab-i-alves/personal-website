---
interface Props {
  count?: number
  maxOpacity?: number
}

const { count = 80, maxOpacity = 0.7 } = Astro.props
---

<div class="stars-canvas" id="stars-canvas"></div>

<script is:inline define:vars={{ count, maxOpacity }}>
function initStars() {
  const canvas = document.getElementById('stars-canvas')
  if (!canvas) return

  canvas.innerHTML = ''
  const chars = ['\u00b7', ':', '*', '.', '+']

  for (let i = 0; i < count; i++) {
    const span = document.createElement('span')
    span.className = 'star'
    const x = Math.random() * window.innerWidth
    const y = Math.random() * window.innerHeight
    span.textContent = chars[Math.floor(Math.random() * chars.length)]
    span.style.left = x + 'px'
    span.style.top = y + 'px'
    span.style.fontSize = (8 + Math.random() * 10) + 'px'
    span.style.setProperty('--dur', (3 + Math.random() * 5) + 's')
    span.style.setProperty('--delay', (Math.random() * 6) + 's')
    span.style.setProperty('--max-opacity', maxOpacity)
    span.style.setProperty('--min-opacity', maxOpacity * 0.15)
    canvas.appendChild(span)
  }
}
initStars()
document.addEventListener('astro:page-load', initStars)
</script>

<style is:global>
  .stars-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .star {
    position: absolute;
    color: var(--text);
    /* Each star is positioned absolutely (top/left), so monospace is not
       required for alignment — using --mono (Inter) keeps the font system
       coherent. */
    font-family: var(--mono);
    animation: twinkle var(--dur) ease-in-out infinite var(--delay);
  }

  @keyframes twinkle {
    0%, 100% { opacity: var(--min-opacity); }
    50% { opacity: var(--max-opacity); }
  }
</style>
