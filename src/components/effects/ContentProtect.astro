<script is:inline>
function initContentProtect() {
  if (document.getElementById('content-protect-overlay')) return
  // Modal overlay
  const overlay = document.createElement('div')
  Object.assign(overlay.style, {
    position: 'fixed', inset: '0', background: 'rgba(48,42,42,0.85)',
    display: 'flex', alignItems: 'center', justifyContent: 'center',
    zIndex: '9999', opacity: '0', pointerEvents: 'none',
    transition: 'opacity 0.3s ease', backdropFilter: 'blur(4px)'
  })

  const box = document.createElement('div')
  Object.assign(box.style, {
    color: '#FCD6E6', fontFamily: "'Inter', sans-serif", textAlign: 'center',
    padding: '3rem 4rem', maxWidth: '520px',
    background: 'rgba(48,42,42,0.9)', borderRadius: '4px',
    border: '1px solid rgba(252,214,230,0.2)'
  })

  box.innerHTML = '<p style="font-size:1.8rem;font-weight:500;margin-bottom:1rem;letter-spacing:0.02em">este conte\u00FAdo \u00E9 protegido</p><p style="font-size:1rem;opacity:0.7;font-weight:350;line-height:1.6">se quiser referenciar algo,<br>fale diretamente comigo</p>'
  overlay.appendChild(box)
  overlay.id = 'content-protect-overlay'
  document.body.appendChild(overlay)

  let hideTimer
  function showModal() {
    clearTimeout(hideTimer)
    overlay.style.opacity = '1'
    overlay.style.pointerEvents = 'auto'
    hideTimer = setTimeout(function() {
      overlay.style.opacity = '0'
      overlay.style.pointerEvents = 'none'
    }, 2000)
  }

  overlay.addEventListener('click', function() {
    clearTimeout(hideTimer)
    overlay.style.opacity = '0'
    overlay.style.pointerEvents = 'none'
  })

  function isNav(e) {
    // Anything interactive — links, buttons, nav, calendar UI, page folds, etc.
    // Selection/copy events on these elements should NEVER trigger the
    // "content protected" modal because they're UI controls, not content.
    return e.target.closest(
      '.page-fold, .nav-chapters, .back-link, .back-link-global, .back-button, ' +
      '.day-cell, .nav-arrow, .panel-close, .pager-link, .pager-toc, ' +
      '.toc-link, .bookmark-row, .chapter-link, .footer-link, .clipping, ' +
      'a, button, nav'
    )
  }

  document.addEventListener('selectstart', function(e) { if (!isNav(e)) { e.preventDefault(); showModal() } })
  document.addEventListener('copy', function(e) { e.preventDefault(); showModal() })
  document.addEventListener('cut', function(e) { e.preventDefault(); showModal() })
  document.addEventListener('contextmenu', function(e) { if (!isNav(e)) { e.preventDefault(); showModal() } })
  document.addEventListener('keydown', function(e) {
    var blocked = false
    if (e.key === 'F12') blocked = true
    if (e.ctrlKey && e.shiftKey && ['I','J','C'].indexOf(e.key) >= 0) blocked = true
    if (e.ctrlKey && e.key === 'u') blocked = true
    if (e.ctrlKey && e.key === 's') blocked = true
    if (e.ctrlKey && e.key === 'a') blocked = true
    if (e.ctrlKey && e.key === 'c') blocked = true
    if (blocked) { e.preventDefault(); showModal() }
  })
}
initContentProtect()
document.addEventListener('astro:page-load', initContentProtect)
</script>
