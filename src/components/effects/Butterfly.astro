                    #@@@@*::.+#+.                =#+.::@@@@@
                    +@@@:...=@@@+.   ..  ..    .=@@@=..:-@@@
                    .@@#:**+@@@@@@:  ::  .:   .%@@@@@+*+-%@+
                     #%=.@@@@@@@@@%=  :  .:  -%@@@@@@@@%=#%.
                     .%@@@@@@@@##%@@= :. .. +@@@#%@%@@@@%@+
                      @@@@*+++*%#*%@@=.: : +@@%##%**++%@@@:
                      -@@#+****#@%##@@-:.:=@@%#@@#***#%%@%
                       @@@%#####*%@%#@@.=:@@%@@#***##%%@@%
                       #@%+=++++==*%@@@+@@@%@#+---=++=+@@-
                       .%@%%%@@@%%%@@@@@@@@@%####%%@@%@@%
                        :+*%@@%@@@%@@@@@@@@@@%%%@@@@%**+.
                          =@@#=+#%##%%@@@@%##**##++@@+
                         +@@%*++*#+++#%%@%##+=+#++*%@@=
                        -@@%++*+*==#%*#+@**#%+-+*+++#@@=
                        -@@%*+=#+*@@+#*=@**##@#+**+**@@*
                        +@@=+#*@#%@=#=*:@+*%*%@#@#*++@@+
                        =@@##+#%%@%%**= @:*=%+@@#%+##%@#
                         %@@=*%+@%+%+*. @.+##@%@%%%=%@%.
                         %@@*%=@@=%=#:  @..%-@=#@=@*%@@
                         .+%@@*@*#@**   #. *#%@+@*%@@%=
                           %@@%@*@+#    .   #+@+@@@@@:
                           .:=@#%%=.        .=#@%@#=-
                              ..:.            .---. `
  ]

  const durations = [300, 150, 120, 200, 120, 150]
  const sequence = [0, 1, 2, 3, 2, 1]
  let i = 0
  let animating = false
  let timer = null
  const el = document.getElementById('butterfly')

  if (el) {
    el.textContent = frames[0]

    function animate() {
      if (!animating) return
      i = (i + 1) % sequence.length
      el.textContent = frames[sequence[i]]
      timer = setTimeout(animate, durations[i])
    }

    el.addEventListener('mouseenter', function() {
      animating = true
      animate()
    })

    el.addEventListener('mouseleave', function() {
      animating = false
      clearTimeout(timer)
      i = 0
      el.textContent = frames[0]
    })
  }
}
initButterfly()
document.addEventListener('astro:page-load', initButterfly)
</script>

<style>
  .butterfly {
    position: fixed;
    top: 50%;
    right: var(--bf-right, 14rem);
    transform: translateY(-50%) scale(var(--bf-scale, 1));
    transform-origin: center right;
    /* EXCEPTION: hard-coded monospace is required because the multi-line
       ASCII art collapses in any proportional font. Courier New is bundled
       with every OS, so this stays consistent cross-platform without an
       extra font download. */
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.15;
    color: var(--text);
    opacity: var(--bf-opacity, 0.6);
    white-space: pre;
    pointer-events: auto;
    user-select: none;
    cursor: default;
    width: 80ch;
    text-align: left;
    z-index: 0;
    margin: 0;
    background: none;
    border: none;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  @media (max-width: 1400px) {
    .butterfly {
      font-size: 10px;
      right: 3rem;
      width: 60ch;
    }
  }

  @media (max-width: 1000px) {
    .butterfly {
      display: none;
    }
  }
</style>
