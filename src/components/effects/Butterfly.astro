        -%@@@%+=+++*+++*+====+#%%**#*+=@@%+****#%#+=--=+*++++++++#@@@%=.
        -#@@@%**++===*#++**%@@#+=#*=*==*@*=*=*#=+#@@#*+==**=++****@@@%*.
        +@@@*=-=+##**#@#*#%@%=-*#==*+: .@:-+*==%*-=%@%##%@#***+==+*@@@+
        =#@@####*+-=#%++%@@%==%*:=*=.  .@+ :=*=-%%=+@@@#+#%*=+*##++%@@#.
         -%@@@+=-=*%*=+@@%#-+%=.+*-.   :@%. :+#-:#@==%@@%=+%%+-=+%@@%*.
         .%@@@#**%#=-=@@+=-*%=:*#:     .@%.  .+%--#@==+#@*==*@*++%@@@-
          .-+%%@@@#+*%@*==#@=-**.      .#*.   .*#-=%@==+%@*++%@@@@%+=.
             :%@#%@%#@**=%@++#=         ..      =#+=#@++*@@#@@%@@+:
              .::==#@*##%%+=-.                   .-=+#@#%#@@*#==-.
                   ....::.                           .---:--.`,
`         :--==--:.                                             .::-==-:.
        .@@@@@@@@@#=:.                                     .:=#%@@@@@%@#
        *@@@@@@@@@@*#==..                                .=+#*@@@@@@@@@@
        #@@@@@@*:::...++#+:.                          :=#*+...::-@@@@@@@
        +@@@@-:.....==@@@@#+.       .     ..        .=#@@@@=-....::#@@@@
        .@@%#+.=***+@@@@%@@@@*:     :     .:      .+%@@@%@@@%+**+:.#%@@+
         #%*==.*@@@@@@@@@@@@@@%#.   :.    .:    .#%@@@@@@@@@@@@@%..=#%*.
         .*%@@%@@@@@@%@@@#*#%%@@%=. .:.   ..  .+%@@@%#*%@@%%@@@@@@%@%+.
          -@@@%%@*+==+++*#%#**#@@@%=..:. .: .+@@@@##*#%#*+*+++*%@%@@@:
           -%@%##+***+**+*#@%####%@@# .:.:..@@@%%##%@@#******##%%#@@=
            +@@@@%########***%%@%##%@+ .=.:#@@%%%@%#******####%%@@@@.
            .@@%++===++++++===+#%@@%@@++@-@@@%@%#*=-----=+++=++*@@@
             *%@%%#%%%@@@@@%%%%%@@@@@@@@@@@@@@%###*####%#%@@@%%@@@%=
              :=+*#%@@@%%%@@@%%%@@@@@@@@@@@@@@@@%%%%%@@@@@@%#***+-.
                 .#@@@#===+#%%###%##%@@@@@@%####***###++++@@%+:
               :+#@@%#*++++*#++++++##%%%@%%##*+===+#+++*%@@@%.
              -%@@@+=++*+++*===+#%%*#*+=@+***#%#+=-+*++++++#@@%=.
              -#@@@**++==*#+**%@#+=#**==@=*=#=+#@@*+=**=++***@@%*.
              +@@@*-=+#**#@##%@%-*#=*+: @-+*=%*-=@%##@#***+=+*@@+
              =#@@###*+=#%+%@@%=%*:=*.  @ :=*-%%=@@@##%*=+##++@@#.
               -%@@+=-*%*=+@%#-%=.+*-   @. :#-:#@=%@@%+%%=+%@@*.
               .%@@#**%=-=@@=-*%:*#:    @.  +%--#@=+#@==*@*+%@@-
                .-%%@@@+*%@*=#@=**.     #.  .*#-=@==+@*++%@@@%+.
                  :%@#@%#@**%@+#=       .     =#+#@++@@#@@@@+:
                   .::=#@*#%%+=-               .-+#@#%@@*#=-.
                       ....:.                     .------.`,
`                --==-:.                                   .:-==-:
              .*@@@@@@@*=.                             .=*%@@@@%@:
              *@@@@@@@@%#==.                         .=+#@@@@@@@@#
              #@@@@@@:::..+#+:                     :=#+..::-@@@@@%
              +@@@@::...==@@@#=.     .   ..      .=#@@@=-...:-@@@=
              .*@%#:=**+@@@@@@@@:    :   .:     .%@@@@@@%+*+:-%@@.
               .%*=.*@@@@@@@@@@@%#.  :.  .:   .#%@@@@@@@@@@%.=#%*
                *%@@@@@@@%@@#*#%@@%= .:. ..  +%@@@##%@%@@@@%@+.
                -@@@%@*+=++*#%**#@@@=..: : .+@@@##*%#**+++%@@@@:
                 -@@%#+**+***%@%###@@# :.:.@@@%##@@%****##%%@@%
                  @@@@%######**%%@%#%@+.=:#@@%%@%#****###%%@@@%
                  #@%+=++++==+#%@%@@+@@@@%@#+---=++=+@@-
                  .*@%%#%%@@@@%%%%@@@@@@@@@@@%##*###%%@@@%@@@=
                    =+*#@@@%%@@@%%@@@@@@@@@@@@%%%%@@@@@%#**+-
                      =#@@#==*#%###%#%@@@@%###***##*++@@%:
                    :+@@@#*+++*#++++##%%@%##*+==+#++*%@@%=
