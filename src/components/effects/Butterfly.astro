.*@@%#+:.=***++@@@@@%@@@@@*:      ::       .:        .+%@@@@%@@@@%++**+:.-#%@@+.
 .#%*==..*@@@@@@@@@@@@@@@@@%#=.    :.      .:     .-#%@@@@@@@@@@@@@@@@%..==#%*.
  .*%@%@%@@@@@@@%%@@@#**#%%@@@%=.  .:.     ..   .+%@@@@%##*%@@%%%@@@@@@@%%@%+.
   -@@@@%%@*++==++++*#%#***#%@@@%=. .:.   .:  .+@@@@%##**#%#*+**++++*%@%@@@@:
