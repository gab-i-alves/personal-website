---
interface Props {
  scale?: number
  right?: string
  opacity?: number
}

const { scale = 1, right = '14rem', opacity = 0.6 } = Astro.props
---

<pre class="butterfly" id="butterfly" style={`--bf-scale: ${scale}; --bf-right: ${right}; --bf-opacity: ${opacity};`}></pre>

