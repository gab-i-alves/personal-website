    user-select: none;
    cursor: default;
    width: 80ch;
    text-align: left;
    z-index: 0;
    margin: 0;
    background: none;
    border: none;
    flex-shrink: 0;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  @media (max-width: 1400px) {
    .butterfly {
      font-size: 9px;
      width: 60ch;
    }
  }

  @media (max-width: 1000px) {
