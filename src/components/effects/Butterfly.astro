  // Each extra art is a plain frame loop: play every frame in order, fixed cadence.
  const normalizedExtras = extraArts.map(function(art) {
    return {
      name: art.name,
      frames: art.frames,
      sequence: art.frames.map(function(_, k) { return k }),
      durations: art.frames.map(function() { return art.frameMs })
    }
  })

  const arts = [butterflyArt].concat(normalizedExtras)
  const art = arts[Math.floor(Math.random() * arts.length)]

  const el = document.getElementById('butterfly')
  if (!el) return

  el.dataset.art = art.name
  el.textContent = art.frames[0]

  let i = 0
  let animating = false
  let timer = null

  function animate() {
    if (!animating) return
    i = (i + 1) % art.sequence.length
    el.textContent = art.frames[art.sequence[i]]
    timer = setTimeout(animate, art.durations[i])
  }

  el.addEventListener('mouseenter', function() {
    animating = true
    animate()
  })

  el.addEventListener('mouseleave', function() {
    animating = false
    clearTimeout(timer)
    i = 0
    el.textContent = art.frames[0]
  })
}
initAsciiArt()
document.addEventListener('astro:page-load', initAsciiArt)
</script>

