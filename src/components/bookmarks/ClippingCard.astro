---
interface Props {
  title: string
  url: string
  colorClass?: string
}

const { title, url } = Astro.props

function getDomain(rawUrl: string) {
  try {
    return new URL(rawUrl).hostname.replace(/^www\./, '')
  } catch {
    return ''
  }
}

const domain = getDomain(url)
---

<a
  class="bookmark-row"
  href={url}
  target="_blank"
  rel="noopener noreferrer"
>
  <div class="bookmark-text">
    <span class="bookmark-domain">{domain}</span>
    <span class="bookmark-title">{title}</span>
  </div>
  <span class="bookmark-arrow" aria-hidden="true">&#x2197;</span>
</a>

<style>
  .bookmark-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 0.5rem;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid rgba(252, 214, 230, 0.05);
    transition:
      background-color var(--dur-normal) var(--ease-out),
      padding var(--dur-normal) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .bookmark-row:last-child {
    border-bottom: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .bookmark-row:hover {
      background-color: rgba(252, 214, 230, 0.025);
      padding-left: 1rem;
    }

    .bookmark-row:hover .bookmark-arrow {
      opacity: 0.7;
      transform: translate(2px, -2px);
    }

    .bookmark-row:hover .bookmark-title {
      color: var(--text);
    }
  }

  .bookmark-row:active {
    transform: scale(0.997);
  }

  .bookmark-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    flex: 1;
  }

  .bookmark-domain {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--text);
    opacity: 0.4;
    letter-spacing: 0.04em;
  }

  .bookmark-title {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 450;
    color: var(--text);
    opacity: 0.85;
    line-height: 1.4;
    letter-spacing: -0.005em;
    transition: color var(--dur-normal) var(--ease-out);
  }

  .bookmark-arrow {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.3;
    transition:
      opacity var(--dur-normal) var(--ease-out),
      transform var(--dur-normal) var(--ease-out);
    flex-shrink: 0;
  }
</style>
