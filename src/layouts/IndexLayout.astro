---
import '@/styles/global.css'
import BaseHead from '@/components/layout/BaseHead.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'

const { title, description } = Astro.props
---

<BaseLayout title={title} description={description} type="page">
  <BaseHead title={title} description={description} slot="head" />
  <BackLink />
  <div class="narrow-layout">
    <main>
      <slot />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style is:global>
  .narrow-layout {
    max-width: 720px;
    margin: 0 auto;
    padding: 6rem 1.5rem 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .narrow-layout main {
    flex: 1;
  }

  @media (max-width: 768px) {
    .narrow-layout {
      padding: 4rem 1.35rem 0;
    }
  }
</style>
