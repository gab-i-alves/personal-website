---
import IndexLayout from '@/layouts/IndexLayout.astro'
import Stars from '@/components/effects/Stars.astro'
import { themeConfig } from '@/config'
---

<IndexLayout title={`404 · ${themeConfig.site.title}`} description="Not Found">
  <Stars count={40} maxOpacity={0.4} />

  <div class="error">
    <h1>404</h1>
    <p class="hint">page not found</p>
    <nav>
      <a href="/">home</a>
      <a href="/posts">posts</a>
    </nav>
  </div>
</IndexLayout>

<style>
  .error {
    margin-top: 4rem;
  }

  .error h1 {
    font-family: var(--display);
    font-size: clamp(4rem, 15vw, 8rem);
    font-weight: normal;
    color: var(--text);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .hint {
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .error nav {
    display: flex;
    gap: 1.5rem;
  }

  .error nav a {
    color: var(--text);
    opacity: 0.6;
    text-decoration: underline;
    text-underline-offset: 0.2rem;
    text-decoration-thickness: 1px;
    transition: opacity 0.2s;
  }

  .error nav a:hover {
    opacity: 1;
  }
</style>
