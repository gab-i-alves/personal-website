---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import CalendarView from '@/components/daily-logs/CalendarView.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { themeConfig } from '@/config'
import { getCollection, render } from 'astro:content'
import { experimental_AstroContainer as AstroContainer } from 'astro/container'

const container = await AstroContainer.create()

const allLogs = await getCollection('dailyLogs')
const sortedLogs = allLogs
  .filter((log) => !log.id.startsWith('_'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const logsWithBody = await Promise.all(sortedLogs.map(async (log) => {
  const d = log.data.date
  const { Content } = await render(log)
  const html = await container.renderToString(Content)
  return {
    slug: log.id,
    year: d.getUTCFullYear(),
    month: d.getUTCMonth(),
    day: d.getUTCDate(),
    mood: log.data.mood || '',
    tags: log.data.tags || [],
    photo: log.data.photo || '',
    body: html
  }
}))
---

<BaseLayout title={`Daily Log · ${themeConfig.site.title}`} description="Daily accountability logs">
  <BaseHead title={`Daily Log · ${themeConfig.site.title}`} description="Daily accountability logs" slot="head" />

  <Stars count={60} maxOpacity={0.4} />
  <BackLink />

  <div class="dailylogs-page">
    <header class="dailylogs-header">
      <h1 class="dailylogs-title">daily logs</h1>
      <p class="dailylogs-subtitle">accountability notes</p>
    </header>

    <CalendarView logs={logsWithBody} />
    <SiteFooter />
  </div>
</BaseLayout>

<style is:global>
  .dailylogs-page {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  .dailylogs-header {
    padding: 3rem 0 2.5rem;
    text-align: center;
  }

  .dailylogs-title {
    font-family: var(--display);
    font-size: var(--display-xl);
    font-weight: normal;
    line-height: 1;
    color: var(--text);
    opacity: 0.92;
    margin: 0;
  }

  .dailylogs-subtitle {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--text-dim);
    opacity: 0.85;
    margin-top: 1.25rem;
    letter-spacing: 0.04em;
    font-style: italic;
  }

  @media (max-width: 600px) {
    .dailylogs-page {
      padding: 0 1.25rem 3rem;
    }
    .dailylogs-header {
      padding: 2rem 0 1.5rem;
    }
  }
</style>
