---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { themeConfig } from '@/config'

const description = 'a quiet shelf — hover to peek, click to open a book'
---

<BaseLayout title={`Library · ${themeConfig.site.title}`} description={description}>
  <BaseHead title={`Library · ${themeConfig.site.title}`} description={description} slot="head" />

  <Stars count={45} maxOpacity={0.35} />
  <BackLink />

  <div class="lib-page">
    <header class="lib-header">
      <h1 class="lib-title">library</h1>
      <p class="lib-subtitle">a quiet shelf — hover to peek, click to open a book</p>
    </header>

    <div class="lib-stage">
      <button class="lib-scene" id="libCard" aria-expanded="false" aria-label="Open a book">
        <!-- The shelf is always present; it only dims and recedes when a book opens. -->
        <img
          class="lib-shelf"
          src="/images/shelf.svg"
          alt="An illustrated bookshelf"
          draggable="false"
        />
        <!-- The book rises in front of the shelf, like one pulled out and opened. -->
        <span class="lib-book-wrap">
          <img
            class="lib-book"
            data-src="/images/book1.svg"
            alt="An open book"
            draggable="false"
          />
        </span>
      </button>

      <p class="lib-hint" id="libHint">
        <span class="hint-dot" aria-hidden="true">&#9671;</span>
        <span class="hint-text">click the shelf to open a book</span>
      </p>
    </div>

    <SiteFooter />
  </div>
</BaseLayout>

<style is:global>
  .lib-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  .lib-header {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .lib-title {
    font-family: var(--display);
    font-size: var(--display-xl);
    font-weight: normal;
    line-height: 1;
    color: var(--text);
    opacity: 0.92;
    margin: 0;
  }

  .lib-subtitle {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    margin: 1.25rem 0 0;
  }

  /* ===== Stage ===== */
  .lib-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .lib-scene {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0;
    margin: 0;
    width: 100%;
    max-width: 680px;
    aspect-ratio: 16 / 9;
    position: relative;
    display: block;
    perspective: 1400px;
  }

  /* Shelf layer — the constant backdrop. */
  .lib-shelf {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 12px;
    user-select: none;
    -webkit-user-drag: none;
    transform-origin: center 60%;
    transition:
      transform var(--dur-slow) var(--ease-out),
      filter 550ms var(--ease-out);
  }

  /* Hover (closed): the shelf leans in slightly and glows. */
  @media (hover: hover) and (pointer: fine) {
    .lib-scene:not(.is-open):hover .lib-shelf {
      transform: translateY(-8px) scale(1.025);
      filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.45))
        drop-shadow(0 0 16px rgba(215, 208, 223, 0.18));
    }
  }

  .lib-scene:active:not(.is-open) .lib-shelf {
    transform: scale(0.99);
  }

  /* Open: shelf dims + softens so the book reads as in front of it. */
  .lib-scene.is-open .lib-shelf {
    transform: scale(1.04);
    filter: brightness(0.45) blur(2px) saturate(0.85);
  }

  /* Book layer — sits in front, centered, smaller than the frame so the shelf
     still frames it. Hidden until opened. */
  .lib-book-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 58%;
    aspect-ratio: 16 / 9;
    transform: translate(-50%, calc(-50% + 9%)) scale(0.82) rotateX(8deg);
    transform-origin: center bottom;
    opacity: 0;
    pointer-events: none;
    transition:
      transform 620ms var(--ease-elegant),
      opacity 460ms var(--ease-out);
    will-change: transform, opacity;
  }

  .lib-book {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 8px;
    user-select: none;
    -webkit-user-drag: none;
    box-shadow:
      0 28px 55px rgba(0, 0, 0, 0.55),
      0 4px 14px rgba(0, 0, 0, 0.4);
  }

  .lib-scene.is-open .lib-book-wrap {
    transform: translate(-50%, -50%) scale(1) rotateX(0deg);
    opacity: 1;
  }

  /* ===== Hint ===== */
  .lib-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: lowercase;
    color: var(--text-faint);
    margin: 0;
    transition: color var(--dur-normal) var(--ease-out);
  }

  .lib-scene:hover ~ .lib-hint {
    color: var(--text-dim);
  }

  .hint-dot {
    font-size: 0.6rem;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .lib-page {
      padding: 0 1.25rem 3rem;
    }
    .lib-header {
      padding: 2rem 0 1.5rem;
    }
    .lib-book-wrap {
      width: 74%;
    }
  }

  /* Reduced motion: calm fades, no rise or blur sweep. */
  @media (prefers-reduced-motion: reduce) {
    .lib-shelf,
    .lib-book-wrap {
      transition: opacity var(--dur-slow) var(--ease-out);
    }
    .lib-book-wrap {
      transform: translate(-50%, -50%) scale(1);
    }
    .lib-scene.is-open .lib-shelf {
      transform: none;
      filter: brightness(0.5);
    }
  }
</style>

<script is:inline>
  function initLibrary() {
    const card = document.getElementById('libCard')
    const hint = document.getElementById('libHint')
    if (!card) return

    // Fires on both the inline call and astro:page-load — bind once, or two
    // click handlers would toggle open/closed and cancel each other out.
    if (card.dataset.bound) return
    card.dataset.bound = '1'

    const bookImg = card.querySelector('.lib-book')

    // Defer the heavy book SVG until it's actually wanted.
    function loadBook() {
      if (bookImg && bookImg.dataset.src) {
        bookImg.src = bookImg.dataset.src
        delete bookImg.dataset.src
      }
    }

    card.addEventListener('pointerenter', loadBook, { once: true })

    function setHint(open) {
      if (!hint) return
      const text = hint.querySelector('.hint-text')
      if (text) text.textContent = open ? 'click to close' : 'click the shelf to open a book'
    }

    card.addEventListener('click', function () {
      loadBook()
      const open = card.classList.toggle('is-open')
      card.setAttribute('aria-expanded', open ? 'true' : 'false')
      card.setAttribute('aria-label', open ? 'Close the book' : 'Open a book')
      setHint(open)
    })
  }

  initLibrary()
  document.addEventListener('astro:page-load', initLibrary)
</script>
