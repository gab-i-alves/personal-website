---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import Butterfly from '@/components/effects/Butterfly.astro'
import { themeConfig } from '@/config'
---

<BaseLayout title={themeConfig.site.title} description={themeConfig.site.description}>
  <BaseHead title={themeConfig.site.title} description={themeConfig.site.description} slot="head" />

  <div class="landing">
    <Stars count={80} maxOpacity={0.7} />

    <div class="landing-group">
      <div class="content">
        <h1>Gabi Alves</h1>
        <nav>
          <a href="/now">right now</a>
          <a href="/posts">read posts</a>
          <a href="/bookmarks">see bookmarks</a>
          <a href="/daily-logs">check daily logs</a>
          <a href="/shelf">shelf</a>
        </nav>
      </div>

      <Butterfly scale={0.65} right="0" opacity={0.45} />
    </div>
    <span class="signature">v0.6 &middot; 2026</span>
  </div>
</BaseLayout>

<style is:global>
  .landing {
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .landing-group {
    display: flex;
    align-items: center;
    gap: 4vw;
    position: relative;
  }

  .landing .content {
    position: relative;
    z-index: 1;
  }

  .landing h1 {
    font-family: var(--display);
    color: var(--text);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: normal;
    letter-spacing: 0.02em;
    line-height: 1.1;
    margin: 0;
    padding: 0;
  }

  .landing nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }

  .landing .signature {
    position: fixed;
    bottom: 2rem;
    right: 2.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text);
    opacity: 0.3;
    letter-spacing: 0.15em;
    z-index: 5;
    text-transform: lowercase;
  }

  .landing nav a {
    font-family: var(--sans);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text);
    opacity: 0.65;
    text-decoration: none;
    letter-spacing: 0.02em;
    position: relative;
    transition:
      opacity var(--dur-normal) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
    transform-origin: left center;
  }

  .landing nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--text);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .landing nav a:hover {
      opacity: 1;
    }
    .landing nav a:hover::after {
      transform: scaleX(1);
    }
  }

  .landing nav a:active {
    transform: scale(var(--press-scale));
    opacity: 0.85;
  }

  @media (max-width: 1000px) {
    .landing-group {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .landing {
      padding: 0 2rem;
    }

    .landing h1 {
      font-size: clamp(3rem, 12vw, 6rem);
    }

    .landing nav a {
      font-size: 1rem;
    }
  }
</style>
