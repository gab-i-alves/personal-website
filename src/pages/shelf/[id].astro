---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { getCollection, render } from 'astro:content'
import { themeConfig } from '@/config'

export async function getStaticPaths() {
  const entries = await getCollection('shelf')
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const { title, author, category, medium, rating, writingScore, duration, tags, url, dateRead } = entry.data

function formatMedium(m: string) {
  return m.replace('-', ' ')
}

function formatDate(d: Date) {
  return `${d.getUTCDate().toString().padStart(2, '0')}.${(d.getUTCMonth() + 1).toString().padStart(2, '0')}.${d.getUTCFullYear()}`
}
---

<BaseLayout title={`${title} · ${themeConfig.site.title}`} description={`notes on ${title}`}>
  <BaseHead title={`${title} · ${themeConfig.site.title}`} description={`notes on ${title}`} slot="head" />

  <Stars count={40} maxOpacity={0.3} />
  <BackLink href="/shelf" label="shelf" />

  <article class="shelf-entry">
    <header class="entry-header">
      <h1 class="entry-title">{title}</h1>
      {author && <p class="entry-author">{author}</p>}

      <div class="entry-meta">
        <span class={`meta-pill meta-pill--${category}`}>{category}</span>
        <span class="meta-pill meta-pill--medium">{formatMedium(medium)}</span>
        {rating && <span class="meta-stat">{rating}/10</span>}
        {writingScore && <span class="meta-stat meta-stat--dim">writing {writingScore}/10</span>}
        {duration && <span class="meta-stat meta-stat--dim">{duration}</span>}
      </div>

      {tags.length > 0 && (
        <div class="entry-tags">
          {tags.map((t) => <span class="entry-tag">{t}</span>)}
        </div>
      )}

      <div class="entry-links">
        {url && <a href={url} target="_blank" rel="noopener" class="entry-source">source</a>}
        {dateRead && <span class="entry-date">read {formatDate(dateRead)}</span>}
      </div>
    </header>

    <div class="entry-notes">
      <Content />
    </div>

    <SiteFooter />
  </article>
</BaseLayout>

<style is:global>
  .shelf-entry {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  .entry-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .entry-title {
    font-family: var(--display);
    font-size: var(--display-md);
    font-weight: normal;
    line-height: 1.15;
    color: var(--text);
    margin: 0 0 0.4rem;
    letter-spacing: 0.02em;
  }

  .entry-author {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-dim);
    margin: 0 0 1.25rem;
  }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
  }

  .meta-pill {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
  }

  .meta-pill--fiction { background: rgba(180, 160, 220, 0.15); color: rgba(200, 180, 240, 0.85); }
  .meta-pill--nonfiction { background: rgba(160, 200, 180, 0.15); color: rgba(180, 220, 200, 0.85); }
  .meta-pill--advice { background: rgba(220, 190, 150, 0.15); color: rgba(240, 210, 170, 0.85); }
  .meta-pill--science { background: rgba(150, 190, 220, 0.15); color: rgba(170, 210, 240, 0.85); }
  .meta-pill--history { background: rgba(200, 170, 160, 0.15); color: rgba(220, 190, 180, 0.85); }
  .meta-pill--medium { background: rgba(252, 214, 230, 0.06); color: var(--text-dim); }

  .meta-stat {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.78rem;
    color: var(--text);
    opacity: 0.7;
    letter-spacing: 0.04em;
  }

  .meta-stat--dim {
    opacity: 0.4;
  }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.85rem;
  }

  .entry-tag {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    padding: 0.18rem 0.45rem;
    border-radius: 3px;
    background: rgba(252, 214, 230, 0.06);
    color: var(--text-dim);
  }

  .entry-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .entry-source {
    font-family: var(--sans);
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
    transition: color var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .entry-source:hover {
      color: var(--text);
    }
  }

  .entry-date {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.72rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }

  /* Notes — long-form markdown */
  .entry-notes {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.8;
    color: var(--text);
    opacity: 0.88;
  }

  .entry-notes p {
    margin: 0 0 1.25rem;
  }

  .entry-notes h2 {
    font-family: var(--sans);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .entry-notes h3 {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    margin: 2rem 0 0.6rem;
  }

  .entry-notes ul, .entry-notes ol {
    padding-left: 1.4rem;
    margin: 0 0 1.25rem;
  }

  .entry-notes li {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .entry-notes blockquote {
    border-left: 2px solid rgba(252, 214, 230, 0.2);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-dim);
  }

  .entry-notes strong {
    font-weight: 500;
    color: var(--text);
  }

  .entry-notes a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: rgba(252, 214, 230, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .entry-notes a:hover {
      text-decoration-color: rgba(252, 214, 230, 0.7);
    }
  }

  .entry-notes code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    background: var(--code-bg);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .entry-notes hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .entry-notes img {
    max-width: 100%;
    border-radius: 3px;
    margin: 1.5rem 0;
  }

  @media (max-width: 600px) {
    .shelf-entry {
      padding: 0 1.25rem 3rem;
    }

    .entry-header {
      padding: 2rem 0 2rem;
    }

    .entry-title {
      font-size: clamp(1.6rem, 5vw, 2.2rem);
    }
  }
</style>
