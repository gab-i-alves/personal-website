---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { getCollection, getEntry, render } from 'astro:content'
import { themeConfig } from '@/config'

const PHASE_RANK = { prop: 0, i: 1, ii: 2, iii: 3 }
const PHASE_NAME = {
  prop: 'Propedêutica',
  i: 'Fase I — Fundamentos',
  ii: 'Fase II — Aprofundamento',
  iii: 'Fase III — Pesquisa'
}
const TRACK_NAME = {
  A: 'Sistemas de Dados & Engenharia',
  B: 'Neurociência Computacional',
  C: 'Bioinformática',
  D: 'Liderança & Sociotécnica',
  E: 'Sistemas, Cognição & Meta'
}

// --- header (program title + subtitle)
const header = await getEntry('program', 'cabecalho')
const { Content: Header } = await render(header!)

// --- subjects (the listing)
const courses = await getCollection('curriculum')
const subjectsSorted = [...courses].sort((a, b) => {
  const p = PHASE_RANK[a.data.phase] - PHASE_RANK[b.data.phase]
  return p !== 0 ? p : a.data.order - b.data.order
})
const subjectRendered = await Promise.all(subjectsSorted.map((s) => render(s)))
const subjectItems = subjectsSorted.map((s, i) => ({
  id: s.id,
  kind: 'subject' as const,
  code: s.data.code,
  title: s.data.title,
  heading: s.data.heading,
  phase: s.data.phase,
  track: s.data.track,
  Content: subjectRendered[i].Content
}))

// --- framework prose, folded into the same rail (one entry each)
const FW = [
  { id: 'visao-geral', group: 'O programa', title: 'Visão geral', code: '§ 1', slug: '01-visao-geral' },
  { id: 'as-fases', group: 'O programa', title: 'As fases', code: '§ 2–5', slug: '02-as-fases' },
  { id: 'bibliografia', group: 'Referências', title: 'Bibliografia', code: '§ 6', slug: '03-bibliografia' },
  { id: 'cursos', group: 'Referências', title: 'Cursos online', code: '§ 7', slug: '04-cursos' },
  { id: 'apendices', group: 'Referências', title: 'Apêndices', code: 'A–C', slug: '05-apendices' }
]
const fwEntries = await Promise.all(FW.map((f) => getEntry('program', f.slug)))
const fwRendered = await Promise.all(fwEntries.map((e) => render(e!)))
const fwItems = FW.map((f, i) => ({
  id: f.id,
  kind: 'framework' as const,
  code: f.code,
  title: f.title,
  Content: fwRendered[i].Content
}))

// --- rail groups, in reading order; subjects sit in the middle as the focus
const phaseGroups = (['prop', 'i', 'ii', 'iii'] as const).map((p) => ({
  label: PHASE_NAME[p],
  items: subjectItems.filter((it) => it.phase === p)
}))
const groups = [
  { label: 'O programa', items: fwItems.filter((it) => ['visao-geral', 'as-fases'].includes(it.id)) },
  ...phaseGroups,
  { label: 'Referências', items: fwItems.filter((it) => ['bibliografia', 'cursos', 'apendices'].includes(it.id)) }
].filter((g) => g.items.length > 0)

const flatItems = groups.flatMap((g) => g.items)
// open on the first subject so the listing — not a wall of text — leads
const defaultId = subjectItems[0].id

const description = 'um currículo autodirigido — as matérias que estou estudando, de propósito'
---

<BaseLayout title={`Currículo · ${themeConfig.site.title}`} description={description}>
  <BaseHead title={`Currículo · ${themeConfig.site.title}`} description={description} slot="head" />

  <Stars count={50} maxOpacity={0.4} />
  <BackLink />

  <div class="cur-page">
    <header class="cur-head">
      <Header />
    </header>

    <div class="cur-layout">
      <!-- master · everything is a rail entry: subjects + the program prose -->
      <nav class="rail" aria-label="Matérias">
        {groups.map((group) => (
          <div class="rail-group">
            <p class="rail-group-label">{group.label}</p>
            {group.items.map((item) => (
              <button
                type="button"
                class={`rail-item rail-item--${item.kind}`}
                data-target={item.id}
                aria-pressed={item.id === defaultId ? 'true' : 'false'}
              >
                <span class="rail-name">{item.title}</span>
                <span class="rail-code">{item.code}</span>
              </button>
            ))}
          </div>
        ))}
      </nav>

      <!-- detail · one pane per entry; only the active one shows -->
      <div class="detail">
        {flatItems.map((item) => {
          const Body = item.Content
          return (
            <article class="pane" data-pane={item.id} hidden={item.id !== defaultId}>
              {item.kind === 'subject' ? (
                <>
                  <h2 class="pane-title">
                    <span class="pane-code">{item.code}</span>
                    <span class="pane-sep">·</span>
                    <span class="pane-name">{item.heading}</span>
                  </h2>
                  <p class="pane-meta">
                    <span class="pane-phase">{PHASE_NAME[item.phase!]}</span>
                    {item.track && (
                      <span class="pane-track">Trilha {item.track} · {TRACK_NAME[item.track]}</span>
                    )}
                  </p>
                </>
              ) : (
                <h2 class="pane-title pane-title--fw">
                  <span class="pane-name">{item.title}</span>
                </h2>
              )}

              <div class="cur-prose pane-body">
                <Body />
              </div>
            </article>
          )
        })}
      </div>
    </div>

    <SiteFooter />
  </div>
</BaseLayout>

<script>
  const rail = document.querySelectorAll<HTMLButtonElement>('.rail-item')
  const panes = document.querySelectorAll<HTMLElement>('.pane')
  const detail = document.querySelector<HTMLElement>('.detail')

  function select(id: string, scroll = false) {
    rail.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.target === id)))
    panes.forEach((p) => {
      p.hidden = p.dataset.pane !== id
    })
    if (history.replaceState) history.replaceState(null, '', `#${id}`)
    // on narrow screens the rail stacks above the pane — jump down to it
    if (scroll && detail && window.matchMedia('(max-width: 860px)').matches) {
      detail.scrollIntoView({ behavior: 'smooth', block: 'start' })
    }
  }

  rail.forEach((btn) => {
    btn.addEventListener('click', () => select(btn.dataset.target!, true))
  })

  const fromHash = decodeURIComponent(location.hash.slice(1))
  if (fromHash && document.querySelector(`[data-pane="${CSS.escape(fromHash)}"]`)) {
    select(fromHash)
  }
</script>

<style is:global>
  .cur-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  /* ===== Compact header — title keeps the display font, nothing else does ===== */
  .cur-head {
    padding: 2.5rem 0 2.25rem;
  }

  .cur-head h1 {
    font-family: var(--display);
    font-size: var(--display-md);
    font-weight: normal;
    line-height: 1.12;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 0;
  }

  .cur-head h3 {
    font-family: var(--sans);
    font-size: 0.98rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-faint);
    letter-spacing: 0.03em;
    margin: 1rem 0 0;
  }

  /* ===== Master / detail layout (default full width) ===== */
  .cur-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.75rem;
    align-items: start;
  }

  /* ===== Rail ===== */
  .rail {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .rail-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rail-group-label {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 0.15rem;
  }

  .rail-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    text-align: left;
    width: 100%;
    box-sizing: border-box;
    padding: 0.7rem 0.95rem;
    cursor: pointer;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(215, 208, 223, 0.015);
    transition:
      background var(--dur-normal) var(--ease-out),
      border-color var(--dur-normal) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .rail-item:hover {
      background: rgba(215, 208, 223, 0.05);
      border-color: rgba(215, 208, 223, 0.18);
      transform: translateX(2px);
    }
  }

  .rail-item:active {
    transform: scale(0.99);
  }

  .rail-item[aria-pressed='true'] {
    border-color: rgba(252, 200, 215, 0.4);
    background: rgba(215, 208, 223, 0.06);
  }

  /* framework entries read as quieter than subjects */
  .rail-item--framework .rail-name {
    font-style: italic;
    color: var(--text-dim);
    font-weight: 400;
  }

  .rail-name {
    font-family: var(--sans);
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--text);
  }

  .rail-code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    white-space: nowrap;
  }

  /* ===== Detail pane ===== */
  .detail {
    min-width: 0;
  }

  .pane {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 2.1rem 2.4rem;
    background: rgba(215, 208, 223, 0.012);
    min-height: 420px;
    animation: paneIn 280ms var(--ease-out) both;
  }

  @keyframes paneIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .pane-title {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin: 0;
    font-weight: normal;
  }

  .pane-code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  .pane-sep {
    color: var(--text-faint);
  }

  .pane-name {
    font-family: var(--sans);
    font-size: 1.45rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .pane-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin: 1rem 0 0;
  }

  .pane-track {
    font-family: var(--sans);
    font-size: 0.74rem;
    font-style: italic;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }

  .pane-phase {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    padding: 0.18rem 0.5rem;
    border-radius: 100px;
    color: rgba(252, 200, 215, 0.95);
    background: rgba(252, 180, 200, 0.16);
  }

  /* ===== Prose inside panes (dark theme, readable sans) ===== */
  .pane-body {
    margin-top: 1.6rem;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-dim);
    letter-spacing: 0.01em;
  }

  .pane-body > :first-child {
    margin-top: 0;
  }

  .pane-body h2 {
    font-family: var(--sans);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 2.2rem 0 1.1rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--border);
  }

  .pane-body h2:first-child {
    margin-top: 0;
  }

  .pane-body h3 {
    font-family: var(--sans);
    font-size: 1.02rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: var(--text);
    margin: 1.7rem 0 0.8rem;
  }

  .pane-body h4 {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.4rem 0 0.6rem;
  }

  .pane-body p {
    margin: 0.9rem 0;
  }

  .pane-body strong {
    color: var(--text);
    font-weight: 500;
  }

  .pane-body em {
    font-style: italic;
    color: var(--text);
    opacity: 0.92;
  }

  .pane-body a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--text-faint);
    text-underline-offset: 2px;
    transition: text-decoration-color var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .pane-body a:hover {
      text-decoration-color: var(--text);
    }
  }

  .pane-body ul,
  .pane-body ol {
    margin: 0.9rem 0;
    padding-left: 1.4rem;
  }

  .pane-body li {
    margin: 0.4rem 0;
    line-height: 1.65;
  }

  .pane-body li::marker {
    color: var(--text-faint);
  }

  .pane-body ul ul,
  .pane-body ol ol,
  .pane-body ul ol,
  .pane-body ol ul {
    margin: 0.4rem 0;
  }

  .pane-body code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.84em;
    padding: 0.1em 0.4em;
    border-radius: 5px;
    background: rgba(215, 208, 223, 0.07);
    border: 1px solid var(--border);
    color: var(--text);
  }

  .pane-body pre {
    background: rgba(215, 208, 223, 0.04);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.4rem;
    margin: 1.4rem 0;
    overflow-x: auto;
  }

  .pane-body pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text-dim);
  }

  .pane-body blockquote {
    margin: 1.4rem 0;
    padding: 1.1rem 1.4rem;
    border: 1px solid var(--border);
    border-left: 2px solid rgba(252, 200, 215, 0.55);
    border-radius: 12px;
    background: rgba(215, 208, 223, 0.025);
    color: var(--text-dim);
  }

  .pane-body blockquote p {
    margin: 0.5rem 0;
  }

  .pane-body blockquote p:first-child {
    margin-top: 0;
  }

  .pane-body blockquote p:last-child {
    margin-bottom: 0;
  }

  .pane-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.4rem 0;
    font-size: 0.85rem;
    display: block;
    overflow-x: auto;
  }

  .pane-body thead th {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    text-align: left;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .pane-body tbody td {
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
    vertical-align: top;
    line-height: 1.5;
  }

  .pane-body tbody tr:last-child td {
    border-bottom: none;
  }

  .pane-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 860px) {
    .cur-layout {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .rail {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .rail-group {
      flex: 1 1 100%;
    }
  }

  @media (max-width: 768px) {
    .cur-page {
      padding: 0 1.25rem 3rem;
    }
    .cur-head {
      padding: 1.75rem 0 1.75rem;
    }
    .pane {
      padding: 1.5rem 1.4rem 1.8rem;
    }
  }
</style>
