---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { getCollection, getEntry, render } from 'astro:content'
import { themeConfig } from '@/config'

// Framework prose: top intro + footer references.
const overviewEntry = await getEntry('program', 'overview')
const appendicesEntry = await getEntry('program', 'appendices')
const { Content: Overview } = await render(overviewEntry!)
const { Content: Appendices } = await render(appendicesEntry!)

const PHASE_RANK = { prop: 0, i: 1, ii: 2, iii: 3 }

const PHASE_NAME = {
  prop: 'Propedêutica',
  i: 'Fase I — Fundamentos',
  ii: 'Fase II — Aprofundamento',
  iii: 'Fase III — Pesquisa'
}

const TRACK_NAME = {
  A: 'Sistemas de Dados & Engenharia',
  B: 'Neurociência Computacional',
  C: 'Bioinformática',
  D: 'Liderança & Sociotécnica',
  E: 'Sistemas, Cognição & Meta'
}

const courses = await getCollection('curriculum')
const subjects = [...courses].sort((a, b) => {
  const p = PHASE_RANK[a.data.phase] - PHASE_RANK[b.data.phase]
  return p !== 0 ? p : a.data.order - b.data.order
})

// Render every subject body once so each pane can show its full description.
const rendered = await Promise.all(subjects.map((s) => render(s)))

// Group the rail by phase, preserving the sorted order.
const phaseOrder = ['prop', 'i', 'ii', 'iii'] as const
const groups = phaseOrder
  .map((phase) => ({
    phase,
    name: PHASE_NAME[phase],
    items: subjects.filter((s) => s.data.phase === phase)
  }))
  .filter((g) => g.items.length > 0)

const description = overviewEntry!.data.description
---

<BaseLayout title={`Currículo · ${themeConfig.site.title}`} description={description}>
  <BaseHead title={`Currículo · ${themeConfig.site.title}`} description={description} slot="head" />

  <Stars count={50} maxOpacity={0.4} />
  <BackLink />

  <div class="cur-page">
    <p class="cur-eyebrow">currículo · programa autodirigido</p>

    <!-- intro · the framework prose lives between the title and the listing -->
    <section class="cur-prose cur-overview">
      <Overview />
    </section>

    <h2 class="cur-section-title">As matérias</h2>
    <p class="cur-section-hint">Selecione uma disciplina à esquerda para ver a ementa completa, os conteúdos, materiais, ferramentas e o checkpoint de avaliação.</p>

    <div class="cur-layout">
      <!-- master · subject rail, grouped by phase -->
      <nav class="rail" aria-label="Matérias">
        {groups.map((group) => (
          <div class="rail-group">
            <p class="rail-group-label">{group.name}</p>
            {group.items.map((course, gi) => (
              <button
                type="button"
                class="rail-item"
                data-target={course.id}
                aria-pressed={course.id === subjects[0].id ? 'true' : 'false'}
                style={`animation-delay: ${gi * 35}ms`}
              >
                <span class="rail-name">{course.data.title}</span>
                <span class="rail-code">{course.data.code}</span>
              </button>
            ))}
          </div>
        ))}
      </nav>

      <!-- detail · one pane per subject; only the active one is shown -->
      <div class="detail">
        {subjects.map((course, i) => {
          const Body = rendered[i].Content
          return (
            <article class="pane" data-pane={course.id} hidden={i !== 0}>
              <div class="pane-head">
                <h3 class="pane-title">
                  <span class="pane-code">{course.data.code}</span>
                  <span class="pane-sep">·</span>
                  <span class="pane-name">{course.data.heading}</span>
                </h3>
              </div>

              <p class="pane-meta">
                <span class="pane-phase">{PHASE_NAME[course.data.phase]}</span>
                {course.data.track && (
                  <span class="pane-track">Trilha {course.data.track} · {TRACK_NAME[course.data.track]}</span>
                )}
              </p>

              <div class="cur-prose pane-body">
                <Body />
              </div>
            </article>
          )
        })}
      </div>
    </div>

    <!-- footer · references and appendices -->
    <section class="cur-prose cur-appendices">
      <Appendices />
    </section>

    <SiteFooter />
  </div>
</BaseLayout>

<script>
  const rail = document.querySelectorAll<HTMLButtonElement>('.rail-item')
  const panes = document.querySelectorAll<HTMLElement>('.pane')

  function select(id: string) {
    rail.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.target === id)))
    panes.forEach((p) => {
      p.hidden = p.dataset.pane !== id
    })
    if (history.replaceState) history.replaceState(null, '', `#${id}`)
  }

  rail.forEach((btn) => {
    btn.addEventListener('click', () => select(btn.dataset.target!))
  })

  // Deep-link: honor #subject-id on load.
  const fromHash = decodeURIComponent(location.hash.slice(1))
  if (fromHash && document.querySelector(`[data-pane="${CSS.escape(fromHash)}"]`)) {
    select(fromHash)
  }
</script>

<style is:global>
  .cur-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  .cur-eyebrow {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: var(--text-faint);
    margin: 2.5rem 0 0;
  }

  /* ===== Section heading between intro and listing ===== */
  .cur-section-title {
    font-family: var(--display);
    font-size: var(--display-md);
    font-weight: normal;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 3.5rem 0 0.6rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .cur-section-hint {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-faint);
    letter-spacing: 0.02em;
    margin: 0 0 2rem;
    max-width: 64ch;
  }

  /* ===== Master / detail layout ===== */
  .cur-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.75rem;
    align-items: start;
  }

  /* ===== Rail ===== */
  .rail {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .rail-group {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .rail-group-label {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 0.15rem;
  }

  .rail-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-align: left;
    width: 100%;
    box-sizing: border-box;
    padding: 0.85rem 1rem;
    cursor: pointer;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(215, 208, 223, 0.015);
    animation: cardIn 350ms var(--ease-out) both;
    transition:
      background var(--dur-normal) var(--ease-out),
      border-color var(--dur-normal) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .rail-item:hover {
      background: rgba(215, 208, 223, 0.05);
      border-color: rgba(215, 208, 223, 0.18);
      transform: translateX(2px);
    }
  }

  .rail-item:active {
    transform: scale(0.99);
  }

  .rail-item[aria-pressed='true'] {
    border-color: rgba(252, 200, 215, 0.4);
    background: rgba(215, 208, 223, 0.06);
  }

  .rail-name {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--text);
  }

  .rail-code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    color: var(--text-faint);
  }

  /* ===== Detail pane ===== */
  .detail {
    min-width: 0;
  }

  .pane {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 2.1rem 2.4rem;
    background: rgba(215, 208, 223, 0.012);
    min-height: 420px;
    animation: paneIn 300ms var(--ease-out) both;
  }

  @keyframes paneIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .pane-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .pane-title {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin: 0;
    font-weight: normal;
  }

  .pane-code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  .pane-sep {
    color: var(--text-faint);
  }

  .pane-name {
    font-family: var(--display);
    font-size: var(--display-md);
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: var(--text);
  }

  .pane-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin: 1rem 0 0;
  }

  .pane-phase,
  .pane-track {
    font-family: var(--sans);
    font-size: 0.74rem;
    font-style: italic;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }

  .pane-phase {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-style: normal;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    padding: 0.18rem 0.5rem;
    border-radius: 100px;
    color: rgba(252, 200, 215, 0.95);
    background: rgba(252, 180, 200, 0.16);
  }

  /* ===== Shared dark-theme prose (overview, panes, appendices) ===== */
  .cur-prose {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-dim);
    letter-spacing: 0.01em;
  }

  .cur-overview {
    margin-top: 1.75rem;
  }

  .cur-appendices {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .pane-body {
    margin-top: 1.6rem;
  }

  .cur-prose > :first-child {
    margin-top: 0;
  }

  .cur-prose h1 {
    font-family: var(--display);
    font-size: var(--display-lg);
    font-weight: normal;
    line-height: 1.08;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 0;
  }

  /* the standalone h3 right under the h1 is the document subtitle */
  .cur-overview h1 + h3 {
    font-family: var(--sans);
    font-size: 1.02rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-faint);
    letter-spacing: 0.03em;
    margin: 0.9rem 0 0;
  }

  .cur-prose h2 {
    font-family: var(--display);
    font-size: 1.55rem;
    font-weight: normal;
    line-height: 1.2;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 3rem 0 1.3rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }

  .cur-prose h3 {
    font-family: var(--display);
    font-size: 1.18rem;
    font-weight: normal;
    letter-spacing: 0.01em;
    color: var(--text);
    margin: 2rem 0 0.9rem;
  }

  .cur-prose h4 {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    margin: 1.6rem 0 0.7rem;
  }

  .cur-prose p {
    margin: 1rem 0;
    max-width: 72ch;
  }

  .cur-prose strong {
    color: var(--text);
    font-weight: 500;
  }

  .cur-prose em {
    font-style: italic;
    color: var(--text);
    opacity: 0.92;
  }

  .cur-prose a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--text-faint);
    text-underline-offset: 2px;
    transition: text-decoration-color var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .cur-prose a:hover {
      text-decoration-color: var(--text);
    }
  }

  .cur-prose ul,
  .cur-prose ol {
    margin: 1rem 0;
    padding-left: 1.4rem;
    max-width: 72ch;
  }

  .cur-prose li {
    margin: 0.4rem 0;
    line-height: 1.65;
  }

  .cur-prose li::marker {
    color: var(--text-faint);
  }

  .cur-prose ul ul,
  .cur-prose ol ol,
  .cur-prose ul ol,
  .cur-prose ol ul {
    margin: 0.4rem 0;
  }

  .cur-prose code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.84em;
    padding: 0.1em 0.4em;
    border-radius: 5px;
    background: rgba(215, 208, 223, 0.07);
    border: 1px solid var(--border);
    color: var(--text);
  }

  .cur-prose pre {
    background: rgba(215, 208, 223, 0.04);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.4rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .cur-prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text-dim);
  }

  .cur-prose blockquote {
    margin: 1.6rem 0;
    padding: 1.1rem 1.4rem;
    border: 1px solid var(--border);
    border-left: 2px solid rgba(252, 200, 215, 0.55);
    border-radius: 12px;
    background: rgba(215, 208, 223, 0.025);
    color: var(--text-dim);
  }

  .cur-prose blockquote p {
    margin: 0.5rem 0;
    max-width: none;
  }

  .cur-prose blockquote p:first-child {
    margin-top: 0;
  }

  .cur-prose blockquote p:last-child {
    margin-bottom: 0;
  }

  .cur-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    display: block;
    overflow-x: auto;
  }

  .cur-prose thead th {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    text-align: left;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .cur-prose tbody td {
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
    vertical-align: top;
    line-height: 1.5;
  }

  .cur-prose tbody tr:last-child td {
    border-bottom: none;
  }

  .cur-prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 860px) {
    .cur-layout {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .rail {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .rail-group {
      flex: 1 1 100%;
    }
  }

  @media (max-width: 768px) {
    .cur-page {
      padding: 0 1.25rem 3rem;
    }
    .pane {
      padding: 1.5rem 1.4rem 1.8rem;
    }
    .cur-prose h2 {
      font-size: 1.35rem;
    }
  }
</style>
