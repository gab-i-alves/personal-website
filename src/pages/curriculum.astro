---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { getCollection } from 'astro:content'
import { themeConfig } from '@/config'

const courses = await getCollection('curriculum')

// Track order + framing — the "departments" of a self-directed catalog.
const TRACKS = [
  { key: 'data', name: 'Data-Intensive Systems', note: 'how data moves, persists, and stays correct at scale' },
  { key: 'mind', name: 'Mind, Brain & Biology', note: 'computation in wetware — from ion channels to genomes' },
  { key: 'org', name: 'People & Organization', note: 'the human system that ships the software' },
  { key: 'theory', name: 'Systems, Ideas & Theory', note: 'the abstractions underneath all of it' }
]

const STATUS_LABEL = {
  active: 'in progress',
  reading: 'reading',
  planned: 'planned',
  done: 'done'
}

const byTrack = TRACKS.map((track) => ({
  ...track,
  courses: courses
    .filter((c) => c.data.track === track.key)
    .sort((a, b) => a.data.order - b.data.order)
}))

// One running index across every card so the load stagger flows top-to-bottom.
let cardIndex = 0

const description = 'a self-directed curriculum — the things i am teaching myself, on purpose'
---

<BaseLayout title={`Curriculum · ${themeConfig.site.title}`} description={description}>
  <BaseHead title={`Curriculum · ${themeConfig.site.title}`} description={description} slot="head" />

  <Stars count={50} maxOpacity={0.4} />
  <BackLink />

  <div class="cur-page">
    <header class="cur-header">
      <p class="cur-eyebrow">field notes · self-directed</p>
      <h1 class="cur-title">personal curriculum</h1>
      <p class="cur-subtitle">the things i'm teaching myself, on purpose</p>
      <p class="cur-meta">
        <span>{courses.length} courses</span>
        <span class="cur-meta-dot">·</span>
        <span>{TRACKS.length} tracks</span>
        <span class="cur-meta-dot">·</span>
        <span>ongoing</span>
      </p>
    </header>

    {byTrack.map((track, t) => (
      <section class="track">
        <div class="track-head">
          <span class="track-num">{String(t + 1).padStart(2, '0')}</span>
          <div class="track-label">
            <h2 class="track-name">{track.name}</h2>
            <p class="track-note">{track.note}</p>
          </div>
          <span class="track-count">{track.courses.length}</span>
        </div>

        <ul class="course-grid">
          {track.courses.map((course) => (
            <li class="course-cell" style={`animation-delay: ${cardIndex++ * 45}ms`}>
              <a href={`/curriculum/${course.id}`} class="course-card" data-track={track.key}>
                <div class="course-top">
                  <span class="course-code">{course.data.code}</span>
                  <span class={`course-status status--${course.data.status}`}>
                    {STATUS_LABEL[course.data.status]}
                  </span>
                </div>
                <h3 class="course-name">{course.data.title}</h3>
                <p class="course-summary">{course.data.summary}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <SiteFooter />
  </div>
</BaseLayout>

<style is:global>
  .cur-page {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  /* ===== Header ===== */
  .cur-header {
    padding: 3rem 0 3.5rem;
    text-align: center;
  }

  .cur-eyebrow {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 1.25rem;
  }

  .cur-title {
    font-family: var(--display);
    font-size: var(--display-xl);
    font-weight: normal;
    line-height: 1;
    letter-spacing: 0.03em;
    color: var(--text);
    opacity: 0.92;
    margin: 0;
  }

  .cur-subtitle {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    margin: 1.25rem 0 0;
  }

  .cur-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin: 1.5rem 0 0;
  }

  .cur-meta-dot {
    opacity: 0.5;
  }

  /* ===== Track ===== */
  .track {
    margin-bottom: 3.5rem;
  }

  .track-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: baseline;
    padding-bottom: 1.5rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  .track-num {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.75rem;
    color: var(--text);
    opacity: 0.35;
    letter-spacing: 0.1em;
  }

  .track-name {
    font-family: var(--display);
    font-size: var(--display-md);
    font-weight: normal;
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 0;
  }

  .track-note {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-dim);
    letter-spacing: 0.02em;
    margin: 0.45rem 0 0;
  }

  .track-count {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.78rem;
    color: var(--text-faint);
    align-self: baseline;
  }

  /* ===== Course grid ===== */
  .course-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
  }

  .course-cell {
    animation: cardIn 350ms var(--ease-out) both;
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .course-card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    height: 100%;
    box-sizing: border-box;
    padding: 1.4rem 1.45rem;
    text-decoration: none;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(252, 214, 230, 0.015);
    transition:
      background var(--dur-normal) var(--ease-out),
      border-color var(--dur-normal) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .course-card:hover {
      background: rgba(252, 214, 230, 0.05);
      border-color: rgba(252, 214, 230, 0.18);
      transform: translateY(-2px);
    }
  }

  .course-card:active {
    transform: scale(0.99);
  }

  .course-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .course-code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
  }

  .course-status {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    padding: 0.18rem 0.5rem;
    border-radius: 100px;
    white-space: nowrap;
    color: var(--text-faint);
    background: rgba(252, 214, 230, 0.05);
  }

  .status--active {
    color: rgba(252, 200, 215, 0.95);
    background: rgba(252, 180, 200, 0.16);
  }

  .status--reading {
    color: rgba(200, 220, 200, 0.9);
    background: rgba(160, 200, 180, 0.14);
  }

  .course-name {
    font-family: var(--sans);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--text);
    margin: 0;
  }

  .course-summary {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 400;
    line-height: 1.55;
    color: var(--text-dim);
    letter-spacing: 0.01em;
    margin: 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .cur-page {
      padding: 0 1.25rem 3rem;
    }
    .cur-header {
      padding: 2rem 0 2.5rem;
    }
    .course-grid {
      grid-template-columns: 1fr;
    }
    .track-head {
      gap: 1rem;
    }
  }
</style>
