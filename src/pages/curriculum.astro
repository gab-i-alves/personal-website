---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { getEntry, render } from 'astro:content'
import { themeConfig } from '@/config'

const entry = await getEntry('program', 'curriculo-autodirigido')
const { Content, headings } = await render(entry!)

// Section rail: the numbered sections + appendices are the only depth-2 headings.
const sections = headings.filter((h) => h.depth === 2)

const description = entry!.data.description
---

<BaseLayout title={`Currículo · ${themeConfig.site.title}`} description={description}>
  <BaseHead title={`Currículo · ${themeConfig.site.title}`} description={description} slot="head" />

  <Stars count={50} maxOpacity={0.4} />
  <BackLink />

  <div class="prog-page">
    <p class="prog-eyebrow">currículo · programa autodirigido</p>

    <div class="prog-shell">
      <!-- sticky section navigator -->
      <aside class="prog-nav" aria-label="Seções">
        <p class="prog-nav-label">índice</p>
        <ol class="prog-nav-list">
          {sections.map((s) => (
            <li>
              <a href={`#${s.slug}`} data-slug={s.slug}>{s.text}</a>
            </li>
          ))}
        </ol>
      </aside>

      <article class="prog-prose">
        <Content />
      </article>
    </div>

    <SiteFooter />
  </div>
</BaseLayout>

<script>
  // Highlight the section currently in view inside the rail.
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.prog-nav-list a'))
  const bySlug = new Map(links.map((a) => [a.dataset.slug, a]))
  const targets = links
    .map((a) => document.getElementById(a.dataset.slug!))
    .filter((el): el is HTMLElement => el !== null)

  let current: HTMLAnchorElement | null = null
  function setActive(slug: string | undefined) {
    const next = slug ? bySlug.get(slug) ?? null : null
    if (next === current) return
    current?.removeAttribute('aria-current')
    next?.setAttribute('aria-current', 'true')
    current = next
  }

  const io = new IntersectionObserver(
    (entries) => {
      const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
      if (visible.length) setActive(visible[0].target.id)
    },
    { rootMargin: '-10% 0px -75% 0px', threshold: 0 }
  )
  targets.forEach((t) => io.observe(t))
</script>

<style is:global>
  .prog-page {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  .prog-eyebrow {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: var(--text-faint);
    margin: 2.5rem 0 0;
  }

  /* ===== Two-column shell: sticky rail + reading column ===== */
  .prog-shell {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 2.5rem;
    align-items: start;
    margin-top: 1.25rem;
  }

  .prog-nav {
    position: sticky;
    top: 2rem;
    align-self: start;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
  }

  .prog-nav-label {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 0.9rem;
  }

  .prog-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .prog-nav-list li {
    margin: 0;
    padding: 0;
  }

  .prog-nav-list a {
    display: block;
    font-family: var(--sans);
    font-size: 0.8rem;
    line-height: 1.35;
    color: var(--text-faint);
    text-decoration: none;
    padding-left: 0.7rem;
    border-left: 1px solid var(--border);
    transition:
      color var(--dur-normal) var(--ease-out),
      border-color var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .prog-nav-list a:hover {
      color: var(--text);
    }
  }

  .prog-nav-list a[aria-current='true'] {
    color: var(--text);
    border-left-color: rgba(252, 200, 215, 0.7);
  }

  /* ===== Reading column (dark-theme prose) ===== */
  .prog-prose {
    min-width: 0;
    font-family: var(--sans);
    font-size: 0.97rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-dim);
    letter-spacing: 0.01em;
  }

  .prog-prose > :first-child {
    margin-top: 0;
  }

  /* document title (the single h1) */
  .prog-prose h1 {
    font-family: var(--display);
    font-size: var(--display-md);
    font-weight: normal;
    line-height: 1.12;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 0.4rem 0 0;
  }

  /* the standalone h3 directly under the title acts as a subtitle */
  .prog-prose h1 + h3 {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-faint);
    letter-spacing: 0.03em;
    margin: 0.9rem 0 0;
    padding: 0;
    border: none;
  }

  .prog-prose h2 {
    font-family: var(--display);
    font-size: 1.65rem;
    font-weight: normal;
    line-height: 1.2;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 3.5rem 0 1.4rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 1.5rem;
  }

  .prog-prose h3 {
    font-family: var(--display);
    font-size: 1.22rem;
    font-weight: normal;
    letter-spacing: 0.01em;
    color: var(--text);
    margin: 2.4rem 0 1rem;
    scroll-margin-top: 1.5rem;
  }

  .prog-prose h4 {
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
    margin: 1.8rem 0 0.8rem;
  }

  .prog-prose p {
    margin: 1.1rem 0;
    max-width: 70ch;
  }

  .prog-prose strong {
    color: var(--text);
    font-weight: 500;
  }

  .prog-prose em {
    font-style: italic;
    color: var(--text);
    opacity: 0.92;
  }

  .prog-prose a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--text-faint);
    text-underline-offset: 2px;
    transition: text-decoration-color var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .prog-prose a:hover {
      text-decoration-color: var(--text);
    }
  }

  /* lists */
  .prog-prose ul,
  .prog-prose ol {
    margin: 1.1rem 0;
    padding-left: 1.4rem;
    max-width: 70ch;
  }

  .prog-prose li {
    margin: 0.45rem 0;
    line-height: 1.7;
  }

  .prog-prose li::marker {
    color: var(--text-faint);
  }

  .prog-prose ul ul,
  .prog-prose ol ol,
  .prog-prose ul ol,
  .prog-prose ol ul {
    margin: 0.45rem 0;
  }

  /* inline code */
  .prog-prose code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.84em;
    padding: 0.1em 0.4em;
    border-radius: 5px;
    background: rgba(215, 208, 223, 0.07);
    border: 1px solid var(--border);
    color: var(--text);
  }

  /* code blocks (Appendix A prereq map) */
  .prog-prose pre {
    background: rgba(215, 208, 223, 0.04);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.4rem;
    margin: 1.6rem 0;
    overflow-x: auto;
  }

  .prog-prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text-dim);
  }

  /* blockquotes -> callout cards */
  .prog-prose blockquote {
    margin: 1.8rem 0;
    padding: 1.1rem 1.4rem;
    border: 1px solid var(--border);
    border-left: 2px solid rgba(252, 200, 215, 0.55);
    border-radius: 12px;
    background: rgba(215, 208, 223, 0.025);
    color: var(--text-dim);
  }

  .prog-prose blockquote p {
    margin: 0.5rem 0;
    max-width: none;
  }

  .prog-prose blockquote p:first-child {
    margin-top: 0;
  }

  .prog-prose blockquote p:last-child {
    margin-bottom: 0;
  }

  /* tables */
  .prog-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.6rem 0;
    font-size: 0.86rem;
    display: block;
    overflow-x: auto;
  }

  .prog-prose thead th {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    text-align: left;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .prog-prose tbody td {
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
    vertical-align: top;
    line-height: 1.5;
  }

  .prog-prose tbody tr:last-child td {
    border-bottom: none;
  }

  .prog-prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .prog-shell {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .prog-nav {
      position: static;
      max-height: none;
      overflow: visible;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid var(--border);
    }
    .prog-nav-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 0.9rem;
    }
    .prog-nav-list a {
      border-left: none;
      padding-left: 0;
    }
    .prog-nav-list a[aria-current='true'] {
      border-left: none;
    }
  }

  @media (max-width: 768px) {
    .prog-page {
      padding: 0 1.25rem 3rem;
    }
    .prog-prose h2 {
      font-size: 1.4rem;
    }
  }
</style>
