---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Stars from '@/components/effects/Stars.astro'
import BackLink from '@/components/layout/BackLink.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { getCollection } from 'astro:content'
import { themeConfig } from '@/config'

const courses = await getCollection('curriculum')

// Track order — used only to cluster the rail; the screen is a flat list.
const TRACK_RANK = { data: 0, mind: 1, org: 2, theory: 3 }

const TRACK_NAME = {
  data: 'Data-Intensive Systems',
  mind: 'Mind, Brain & Biology',
  org: 'People & Organization',
  theory: 'Systems, Ideas & Theory'
}

const STATUS_LABEL = {
  active: 'in progress',
  reading: 'reading',
  planned: 'planned',
  done: 'done'
}

// Rail order: by track, then by the in-track order field.
const subjects = [...courses].sort((a, b) => {
  const t = TRACK_RANK[a.data.track] - TRACK_RANK[b.data.track]
  return t !== 0 ? t : a.data.order - b.data.order
})

const description = 'a self-directed curriculum — the things i am teaching myself, on purpose'
---

<BaseLayout title={`Curriculum · ${themeConfig.site.title}`} description={description}>
  <BaseHead title={`Curriculum · ${themeConfig.site.title}`} description={description} slot="head" />

  <Stars count={50} maxOpacity={0.4} />
  <BackLink />

  <div class="cur-page">
    <header class="cur-header">
      <h1 class="cur-title">personal curriculum</h1>
      <p class="cur-subtitle">{description}</p>
    </header>

    <div class="cur-layout">
      <!-- master · subject rail -->
      <nav class="rail" aria-label="Subjects">
        {subjects.map((course, i) => (
          <button
            type="button"
            class="rail-item"
            data-target={course.id}
            aria-pressed={i === 0 ? 'true' : 'false'}
            style={`animation-delay: ${i * 40}ms`}
          >
            <span class="rail-name">{course.data.title}</span>
            <span class="rail-code">{course.data.code}</span>
          </button>
        ))}
      </nav>

      <!-- detail · one pane per subject, only the active one is shown -->
      <div class="detail">
        {subjects.map((course, i) => (
          <article class="pane" id={`pane-${course.id}`} data-pane={course.id} hidden={i !== 0}>
            <div class="pane-head">
              <h2 class="pane-title">
                <span class="pane-code">{course.data.code}</span>
                <span class="pane-sep">·</span>
                <span class="pane-name">{course.data.title}</span>
              </h2>
              <a class="pane-open" href={`/curriculum/${course.id}`}>open notebook →</a>
            </div>

            <p class="pane-meta">
              <span class="pane-track">{TRACK_NAME[course.data.track]}</span>
              <span class={`pane-status status--${course.data.status}`}>
                {STATUS_LABEL[course.data.status]}
              </span>
            </p>

            <p class="pane-summary">{course.data.summary}</p>

            <h3 class="prog-heading">Progress</h3>

            {course.data.progress.length > 0 ? (
              <table class="prog-table">
                <thead>
                  <tr>
                    <th class="col-name">Name</th>
                    <th class="col-type">Type</th>
                    <th class="col-status">Status</th>
                    <th class="col-rating">Rating</th>
                  </tr>
                </thead>
                <tbody>
                  {course.data.progress.map((item) => (
                    <tr>
                      <td class="col-name">{item.name}</td>
                      <td class="col-type">{item.type}</td>
                      <td class="col-status">
                        <span class={`prog-pill status--${item.status}`}>
                          {STATUS_LABEL[item.status]}
                        </span>
                      </td>
                      <td class="col-rating">
                        {item.rating ? `${item.rating}/10` : <span class="prog-dash">—</span>}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <p class="prog-empty">Nothing logged yet — syllabus still taking shape.</p>
            )}
          </article>
        ))}
      </div>
    </div>

    <SiteFooter />
  </div>
</BaseLayout>

<script>
  const rail = document.querySelectorAll<HTMLButtonElement>('.rail-item')
  const panes = document.querySelectorAll<HTMLElement>('.pane')

  function select(id: string) {
    rail.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.target === id)))
    panes.forEach((p) => {
      p.hidden = p.dataset.pane !== id
    })
    if (history.replaceState) history.replaceState(null, '', `#${id}`)
  }

  rail.forEach((btn) => {
    btn.addEventListener('click', () => select(btn.dataset.target!))
  })

  // Deep-link: honor #subject-id on load.
  const fromHash = decodeURIComponent(location.hash.slice(1))
  if (fromHash && document.querySelector(`[data-pane="${CSS.escape(fromHash)}"]`)) {
    select(fromHash)
  }
</script>

<style is:global>
  .cur-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  /* ===== Header ===== */
  .cur-header {
    padding: 2.5rem 0 2.5rem;
  }

  .cur-title {
    font-family: var(--display);
    font-size: var(--display-lg);
    font-weight: normal;
    line-height: 1;
    letter-spacing: 0.03em;
    color: var(--text);
    opacity: 0.92;
    margin: 0;
  }

  .cur-subtitle {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    font-style: italic;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    margin: 1rem 0 0;
    max-width: 60ch;
  }

  /* ===== Master / detail layout ===== */
  .cur-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.75rem;
    align-items: start;
  }

  /* ===== Rail ===== */
  .rail {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .rail-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-align: left;
    width: 100%;
    box-sizing: border-box;
    padding: 0.95rem 1.1rem;
    cursor: pointer;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(215, 208, 223, 0.015);
    animation: cardIn 350ms var(--ease-out) both;
    transition:
      background var(--dur-normal) var(--ease-out),
      border-color var(--dur-normal) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .rail-item:hover {
      background: rgba(215, 208, 223, 0.05);
      border-color: rgba(215, 208, 223, 0.18);
      transform: translateX(2px);
    }
  }

  .rail-item:active {
    transform: scale(0.99);
  }

  .rail-item[aria-pressed='true'] {
    border-color: rgba(215, 208, 223, 0.28);
    background: rgba(215, 208, 223, 0.06);
  }

  .rail-name {
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--text);
  }

  .rail-code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    color: var(--text-faint);
  }

  /* ===== Detail pane ===== */
  .detail {
    min-width: 0;
  }

  .pane {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 2.1rem 2.4rem;
    background: rgba(215, 208, 223, 0.012);
    min-height: 420px;
    animation: paneIn 300ms var(--ease-out) both;
  }

  @keyframes paneIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .pane-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .pane-title {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin: 0;
    font-weight: normal;
  }

  .pane-code {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  .pane-sep {
    color: var(--text-faint);
  }

  .pane-name {
    font-family: var(--display);
    font-size: var(--display-md);
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: var(--text);
  }

  .pane-open {
    font-family: var(--sans);
    font-size: 0.78rem;
    color: var(--text-faint);
    text-decoration: none;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: color var(--dur-normal) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .pane-open:hover {
      color: var(--text);
    }
  }

  .pane-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 1rem 0 0;
  }

  .pane-track {
    font-family: var(--sans);
    font-size: 0.74rem;
    font-style: italic;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }

  .pane-status,
  .prog-pill {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    padding: 0.18rem 0.5rem;
    border-radius: 100px;
    white-space: nowrap;
    color: var(--text-faint);
    background: rgba(215, 208, 223, 0.05);
  }

  .status--active {
    color: rgba(252, 200, 215, 0.95);
    background: rgba(252, 180, 200, 0.16);
  }

  .status--reading {
    color: rgba(200, 220, 200, 0.9);
    background: rgba(160, 200, 180, 0.14);
  }

  .status--done {
    color: rgba(190, 205, 235, 0.95);
    background: rgba(160, 185, 235, 0.14);
  }

  .pane-summary {
    font-family: var(--sans);
    font-size: 0.98rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-dim);
    letter-spacing: 0.01em;
    margin: 1.4rem 0 0;
    max-width: 64ch;
  }

  /* ===== Progress table ===== */
  .prog-heading {
    font-family: var(--display);
    font-size: 1.3rem;
    font-weight: normal;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 2.2rem 0 1.1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .prog-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--sans);
  }

  .prog-table th {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    text-align: left;
    padding: 0 0.75rem 0.85rem;
  }

  .prog-table td {
    font-size: 0.88rem;
    color: var(--text-dim);
    padding: 0.85rem 0.75rem;
    border-top: 1px solid var(--border);
    vertical-align: middle;
  }

  .prog-table .col-name {
    color: var(--text);
    width: 48%;
  }

  .col-type {
    text-transform: lowercase;
  }

  .col-rating {
    font-family: var(--mono);
    font-feature-settings: var(--mono-feat);
    color: var(--text);
  }

  .prog-dash {
    color: var(--text-faint);
  }

  .prog-empty {
    font-family: var(--sans);
    font-size: 0.88rem;
    font-style: italic;
    color: var(--text-faint);
    margin: 0.5rem 0 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 860px) {
    .cur-layout {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .rail {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .rail-item {
      flex: 1 1 calc(50% - 0.35rem);
      min-width: 140px;
    }
  }

  @media (max-width: 768px) {
    .cur-page {
      padding: 0 1.25rem 3rem;
    }
    .cur-header {
      padding: 1.75rem 0 2rem;
    }
    .pane {
      padding: 1.5rem 1.4rem 1.8rem;
    }
    .pane-head {
      flex-direction: column;
      gap: 0.5rem;
    }
  }

  @media (max-width: 520px) {
    .rail-item {
      flex: 1 1 100%;
    }
    .col-type {
      display: none;
    }
    .prog-table th.col-type {
      display: none;
    }
  }
</style>
